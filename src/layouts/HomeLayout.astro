---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

import Head from "../components/Head.astro";

const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
	<Head title={title} description={description} />

	<body>
		<div class={isDev ? "dev-debug page-container" : "page-container"}>
			<div class="text-container">
				<slot />
			</div>
		</div>
	</body>
</html>
<style is:global>
	:root {
		font-family: "Noto Serif", serif;
		font-weight: 400;
		font-style: normal;

		font-synthesis: none;
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	* {
		padding: 0;
		margin: 0;
	}

	.dev-debug * {
		outline: 1px solid red;
	}

	a,
	a:visited {
		color: inherit;
	}

	.page-container {
		background-color: #232d25;
		color: #fefaf4;
		display: flex;
		width: 100%;
		height: 100vh;
		justify-content: center;
		align-items: center;
	}

	.text-container {
		max-width: 550px;
		font-size: 20px;
		padding: 32px 16px;
	}
</style>
